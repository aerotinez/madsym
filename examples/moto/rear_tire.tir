[MDI_HEADER]
FILE_TYPE                = 'tir'
FILE_VERSION             = 3.0
FILE_FORMAT              = 'ASCII'
!
! Generated from rear_tire MATLAB struct
!
! Model name: Magic Formula v6.2
!
$----------------------------------------------------------------units
[UNITS]
LENGTH                   = 'meter'
FORCE                    = 'newton'
ANGLE                    = 'radians'
MASS                     = 'kg'
TIME                     = 'second'
$----------------------------------------------------------------model
[MODEL]
FITTYP                   = 62                $Magic Formula Version number
TYRESIDE                 = 'Right'
LONGVL                   = 16.6              $Nominal speed
PROPERTY_FILE_FORMAT     = 'MF-TYRE'
FUNCTION_NAME            = ''
N_TIRE_STATES            = 5
USE_MODE                 = 114               $Tire use mode switch (ADAMS only)
PLYSTEER                 = 'true'            $Plysteer
TURNSLIP                 = 'true'            $Turnslip
VXLOW                    = 1                 $Lower boundary of slip calculation
$------------------------------------------------------------dimension
[DIMENSION]
UNLOADED_RADIUS          = 0.325             $Free tire radius
WIDTH                    = 0.19              $Nominal section width of the tire
ASPECT_RATIO             = 0.55              $Nominal aspect ratio
RIM_RADIUS               = 0.2159            $Nominal rim radius
RIM_WIDTH                = 0.1524            $Rim width
$-------------------------------------------------operating_conditions
[OPERATING_CONDITIONS]
INFLPRES                 = 290000            $Tire inflation pressure
NOMPRES                  = 290000            $Nominal tire inflation pressure
$--------------------------------------------------------------inertia
[INERTIA]
MASS                     = 6.21              $Tire Mass
IXX                      = 0.207             $Tire diametral moment of inertia
IYY                      = 0.507             $Tire polar moment of inertia
$-------------------------------------------------------------vertical
[VERTICAL]
FNOMIN                   = 1941.7            $Nominal wheel load
VERTICAL_STIFFNESS       = 174720            $Tire vertical stiffness
VERTICAL_DAMPING         = 500               $Tire vertical damping
MC_CONTOUR_A             = 1.2781            $Motorcycle contour ellipse A
MC_CONTOUR_B             = 2.9277            $Motorcycle contour ellipse B
BREFF                    = 1.2821            $Low load stiffness effective rolling radius
DREFF                    = 0.4139            $Peak value of effective rolling radius
FREFF                    = 0.00024759        $High load stiffness effective rolling radius
Q_RE0                    = 0.997             $Ratio of free tire radius with nominal tire radius
Q_V1                     = 6.28e-05          $Tire radius increase with speed
Q_V2                     = 0.0816            $Vertical stiffness increase with speed
Q_FZ2                    = 87.6745           $Quadratic term in load vs. deflection
Q_FCX                    = 0                 $Longitudinal force influence on vertical stiffness
Q_FCY                    = 0                 $Lateral force influence on vertical stiffness
Q_FCY2                   = 1.8572            $Explicit load dependency for including the lateral force influence on vertical stiffness
Q_CAM                    = 0                 $Stiffness reduction due to camber
Q_CAM1                   = -127.9787         $Linear load dependent camber angle effect on vertical stiffness
Q_CAM2                   = 361.194           $Quadratic load dependent camber angle effect on vertical stiffness
Q_CAM3                   = 3.7323            $Linear reduction of stiffness with load and camber angle
Q_FYS1                   = -130300           $Constant camber and slip angle effect on vertical stiffness
Q_FYS2                   = -14697            $Linear camber and slip angle effect on vertical stiffness
Q_FYS3                   = -54328            $Quadratic camber and slip angle effect on vertical stiffness
PFZ1                     = 0                 $Pressure effect on vertical stiffness
BOTTOM_OFFST             = 0.01              $Distance to rim when bottoming starts to occur
BOTTOM_STIFF             = 2000000           $Vertical stiffness of bottomed tire
$-----------------------------------------------------------structural
[STRUCTURAL]
LONGITUDINAL_STIFFNESS   = 303430            $Tire overall longitudinal stiffness
LATERAL_STIFFNESS        = 134040            $Tire overall lateral stiffness
YAW_STIFFNESS            = 1092.6            $Tire overall yaw stiffness
DAMP_VLOW                = 0.001             $Additional low speed damping (proportional to stiffness)
PCFX1                    = 0.4676            $Tire overall longitudinal stiffness vertical deflection dependency linear term
PCFX2                    = 0.1143            $Tire overall longitudinal stiffness vertical deflection dependency quadratic term
PCFX3                    = 0                 $Tire overall longitudinal stiffness pressure dependency
PCFY1                    = 0.5               $Tire overall lateral stiffness vertical deflection dependency linear term
PCFY2                    = 0.5               $Tire overall lateral stiffness vertical deflection dependency quadratic term
PCFY3                    = 0                 $Tire overall lateral stiffness pressure dependency
PCMZ1                    = 0                 $Tire overall yaw stiffness pressure dependency
$--------------------------------------------------------contact_patch
[CONTACT_PATCH]
Q_RA1                    = 0.9689            $Square root term in contact length equation
Q_RA2                    = 0.6038            $Linear term in contact length equation
Q_RB1                    = 0.3179            $Root term in contact width equation
Q_RB2                    = 1.4929            $Linear term in contact width equation
$---------------------------------------------inflation_pressure_range
[INFLATION_PRESSURE_RANGE]
PRESMIN                  = 240000            $Minimum valid tire inflation pressure
PRESMAX                  = 300000            $Maximum valid tire inflation pressure
$------------------------------------------------------long_slip_range
[LONG_SLIP_RANGE]
KPUMIN                   = -0.5              $Minimum valid wheel slip
KPUMAX                   = 0.5               $Maximum valid wheel slip
$-----------------------------------------------------slip_angle_range
[SLIP_ANGLE_RANGE]
ALPMIN                   = -0.17             $Minimum valid slip angle
ALPMAX                   = 0.17              $Maximum valid slip angle
$----------------------------------------------inclination_angle_range
[INCLINATION_ANGLE_RANGE]
CAMMIN                   = -0.9              $Minimum valid camber angle
CAMMAX                   = 0.9               $Maximum valid camber angle
$-------------------------------------------------vertical_force_range
[VERTICAL_FORCE_RANGE]
FZMIN                    = 100               $Minimum allowed wheel load
FZMAX                    = 3227              $Maximum allowed wheel load
$-------------------------------------------------scaling_coefficients
[SCALING_COEFFICIENTS]
LFZO                     = 1                 $Scale factor of nominal (rated) load
LCX                      = 1                 $Scale factor of Fx shape factor
LMUX                     = 1                 $Scale factor of Fx peak friction coefficient
LEX                      = 1                 $Scale factor of Fx curvature factor
LKX                      = 1                 $Scale factor of Fx slip stiffness
LHX                      = 1                 $Scale factor of Fx horizontal shift
LVX                      = 1                 $Scale factor of Fx vertical shift
LCY                      = 1                 $Scale factor of Fy shape factor
LMUY                     = 1                 $Scale factor of Fy peak friction coefficient
LEY                      = 1                 $Scale factor of Fy curvature factor
LKY                      = 1                 $Scale factor of Fy cornering stiffness
LHY                      = 1                 $Scale factor of Fy horizontal shift
LVY                      = 1                 $Scale factor of Fy vertical shift
LTR                      = 1                 $Scale factor of Peak of pneumatic trail
LRES                     = 1                 $Scale factor for offset of Mz residual torque
LXAL                     = 1                 $Scale factor of alpha influence on Fx
LYKA                     = 1                 $Scale factor of kappa influence on Fy
LVYKA                    = 1                 $Scale factor of kappa induced Fy
LS                       = 1                 $Scale factor of Moment arm of Fx
LKYC                     = 1                 $Scale factor of Fy camber stiffness
LKZC                     = 1                 $Scale factor of Mz camber stiffness
LVMX                     = 1                 $Scale factor of Mx vertical shift
LMX                      = 1                 $Scale factor of Mx overturning moment
LMY                      = 1                 $Scale factor of rolling resistance torque
LMP                      = 1                 $Scale factor of Mz parking torque
LCZ                      = 1                 $Scale factor radial tire stiffness
LMUV                     = 0                 $Scale factor with slip speed decaying friction
$--------------------------------------------longitudinal_coefficients
[LONGITUDINAL_COEFFICIENTS]
PCX1                     = 1.5657            $Shape factor Cfx for longitudinal force
PDX1                     = 1.4068            $Longitudinal friction Mux at Fznom
PDX2                     = -0.0254           $Variation of friction Mux with load
PDX3                     = 0.2223            $Variation of friction Mux with camber
